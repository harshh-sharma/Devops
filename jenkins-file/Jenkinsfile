pipeline {
    agent {
        label 'linux'
    }

    stages {

        stage('Build') {
            steps {
                echo 'Build Started'
                sh 'invalid-command'
            }
        }

        stage('Test') {
            steps {
                echo 'Running Tests'
            }
        }
    }

    post {

        always {
            echo 'Always runs'
        }

        success {
            echo 'Build Successful'
        }

        failure {
            echo 'Build Failed'
        }
    }
}
