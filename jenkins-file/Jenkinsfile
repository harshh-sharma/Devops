pipeline {
    agent {
        label 'agent'
    }

    stages {

        stage('Checkout') {
             steps {
                sh 'pwd'
                sh 'ls -la'
            }
        }

        stage('Install') {
            steps {
                dir('jenkins-file') {
                    sh 'npm install'
                }
            }
        }

        stage('Test') {
            steps {
                dir('jenkins-file') {
                    sh 'npm test'
                }
            }
        }

        stage('Build') {
            steps {
                dir('jenkins-file') {
                    sh 'npm run build'
                }
            }
        }
    }
}
