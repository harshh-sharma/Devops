pipeline {
    agent {
        label 'agent'
    }

    environment {
        APP_NAME = 'node-app'
        ENVIRONMENT = 'dev'
    }

    stages {

        stage('Print Variables') {
            steps {
                echo "App: ${APP_NAME}"
                echo "Environment: ${ENVIRONMENT}"

                sh 'echo $APP_NAME'
                sh 'echo $ENVIRONMENT'
            }
        }
    }
}
